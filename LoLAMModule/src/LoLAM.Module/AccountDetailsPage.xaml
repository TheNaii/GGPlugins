<UserControl x:Class="LoLAM.Module.AccountDetailsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ReadOnlyBox" TargetType="TextBox" BasedOn="{StaticResource FieldBox}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <Style x:Key="ReadOnlyCombo" TargetType="ComboBox" BasedOn="{StaticResource FieldCombo}">
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <!-- ComboBoxItem: force readable dark text so it's visible in the white popup -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1E3A5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Icon button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#475569"/>
                                <Setter Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Width="420"
                    HorizontalAlignment="Left"
                    Margin="28,20,28,28">

            <!-- ── Header ── -->
            <DockPanel Margin="0,0,0,20">
                <Button DockPanel.Dock="Left"
                        Content="← Back"
                        Width="76" Height="28"
                        Click="Back_Click"/>
                <TextBlock DockPanel.Dock="Left"
                           Text="Account Details"
                           FontSize="17" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
                <TextBlock x:Name="SaveStatus"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           FontSize="11" Opacity="0.6"/>
            </DockPanel>

            <!-- ── Summoner Name ── -->
            <TextBlock Text="Summoner Name" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="SummonerNameBox"
                     Style="{StaticResource FieldBox}"
                     TextChanged="Field_TextChanged"/>

            <!-- ── Riot Tag ──
                 Simple approach: a "#" TextBlock floated inside a Grid over the TextBox,
                 with left padding on the TextBox to make room. No custom template needed. -->
            <TextBlock Text="Riot Tag" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,0,0,12" Height="32">
                <TextBox x:Name="RiotTagBox"
                         Padding="28,0,8,0"
                         VerticalContentAlignment="Center"
                         TextChanged="Field_TextChanged"/>
                <!-- # overlay — sits on top of the TextBox, left-aligned, non-interactive -->
                <TextBlock Text="#"
                           FontWeight="SemiBold"
                           FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="9,0,0,0"
                           IsHitTestVisible="False"
                           Opacity="0.65"/>
            </Grid>

            <!-- ── Server ── -->
            <TextBlock Text="Server" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="ServerCombo"
                      Style="{StaticResource FieldCombo}"
                      SelectionChanged="Field_SelectionChanged">
                <!-- Europe -->
                <ComboBoxItem Content="EUW — Europe West"               Tag="EUW"/>
                <ComboBoxItem Content="EUNE — Europe Nordic &amp; East"  Tag="EUNE"/>
                <ComboBoxItem Content="TR — Turkey"                     Tag="TR"/>
                <ComboBoxItem Content="RU — Russia"                     Tag="RU"/>
                <ComboBoxItem Content="ME — Middle East"                Tag="ME"/>
                <!-- Americas -->
                <ComboBoxItem Content="NA — North America"              Tag="NA"/>
                <ComboBoxItem Content="BR — Brazil"                     Tag="BR"/>
                <ComboBoxItem Content="LAN — Latin America North"       Tag="LAN"/>
                <ComboBoxItem Content="LAS — Latin America South"       Tag="LAS"/>
                <!-- Asia / Pacific -->
                <ComboBoxItem Content="KR — Korea"                      Tag="KR"/>
                <ComboBoxItem Content="JP — Japan"                      Tag="JP"/>
                <ComboBoxItem Content="OCE — Oceania"                   Tag="OCE"/>
                <ComboBoxItem Content="PH — Philippines"                Tag="PH"/>
                <ComboBoxItem Content="SG — Singapore / MY / ID"        Tag="SG"/>
                <ComboBoxItem Content="TH — Thailand"                   Tag="TH"/>
                <ComboBoxItem Content="TW — Taiwan / HK / MO"           Tag="TW"/>
                <ComboBoxItem Content="VN — Vietnam"                    Tag="VN"/>
            </ComboBox>

            <!-- ── Username ── -->
            <TextBlock Text="Username (Login)" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UsernameBox"
                         Grid.Column="0" Height="32"
                         Padding="8,0" VerticalContentAlignment="Center"
                         TextChanged="Field_TextChanged"/>
                <Button Grid.Column="1" Style="{StaticResource IconBtn}"
                        Margin="6,0,0,0" ToolTip="Copy username"
                        Click="CopyUsername_Click">
                    <TextBlock Text="⎘" FontSize="15"/>
                </Button>
            </Grid>

            <!-- ── Password ── -->
            <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <PasswordBox x:Name="PasswordBox"
                             Grid.Column="0" Height="32"
                             Padding="8,0" VerticalContentAlignment="Center"
                             PasswordChanged="PasswordBox_PasswordChanged"/>
                <TextBox x:Name="PasswordRevealBox"
                         Grid.Column="0" Height="32"
                         Padding="8,0" VerticalContentAlignment="Center"
                         Visibility="Collapsed"
                         TextChanged="PasswordReveal_TextChanged"/>

                <Button Grid.Column="1" Style="{StaticResource IconBtn}"
                        Margin="6,0,4,0" ToolTip="Show / hide password"
                        Click="RevealPassword_Click">
                    <TextBlock x:Name="RevealIcon" Text="👁" FontSize="14"/>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource IconBtn}"
                        ToolTip="Copy password"
                        Click="CopyPassword_Click">
                    <TextBlock Text="⎘" FontSize="15"/>
                </Button>
            </Grid>

            <!-- ── Tier + Division (read-only / auto) ── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Tier" Style="{StaticResource FieldLabel}" Margin="0"/>
                        <TextBlock DockPanel.Dock="Right" Text="auto"
                                   FontSize="10" Opacity="0.35" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ComboBox x:Name="TierCombo" Style="{StaticResource ReadOnlyCombo}">
                        <ComboBoxItem Content="Unranked"    Tag="Unranked"/>
                        <ComboBoxItem Content="Iron"        Tag="Iron"/>
                        <ComboBoxItem Content="Bronze"      Tag="Bronze"/>
                        <ComboBoxItem Content="Silver"      Tag="Silver"/>
                        <ComboBoxItem Content="Gold"        Tag="Gold"/>
                        <ComboBoxItem Content="Platinum"    Tag="Platinum"/>
                        <ComboBoxItem Content="Emerald"     Tag="Emerald"/>
                        <ComboBoxItem Content="Diamond"     Tag="Diamond"/>
                        <ComboBoxItem Content="Master"      Tag="Master"/>
                        <ComboBoxItem Content="Grandmaster" Tag="Grandmaster"/>
                        <ComboBoxItem Content="Challenger"  Tag="Challenger"/>
                        <ComboBoxItem Content="Unavailable" Tag="Unavailable"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Division" Style="{StaticResource FieldLabel}" Margin="0"/>
                        <TextBlock DockPanel.Dock="Right" Text="auto"
                                   FontSize="10" Opacity="0.35" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ComboBox x:Name="DivisionCombo" Style="{StaticResource ReadOnlyCombo}">
                        <ComboBoxItem Content="—"   Tag=""/>
                        <ComboBoxItem Content="I"   Tag="I"/>
                        <ComboBoxItem Content="II"  Tag="II"/>
                        <ComboBoxItem Content="III" Tag="III"/>
                        <ComboBoxItem Content="IV"  Tag="IV"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- ── Games Played (read-only / auto) ── -->
            <DockPanel Margin="0,8,0,4">
                <TextBlock Text="Games Played This Split" Style="{StaticResource FieldLabel}" Margin="0"/>
                <TextBlock DockPanel.Dock="Right" Text="auto"
                           FontSize="10" Opacity="0.35" VerticalAlignment="Center"/>
            </DockPanel>
            <TextBox x:Name="GamesPlayedBox" Style="{StaticResource ReadOnlyBox}"/>

            <!-- ── Xbox Linked ── -->
            <CheckBox x:Name="XboxLinkedBox"
                      Content="Xbox Game Pass Linked"
                      Margin="0,2,0,14"
                      Checked="Field_CheckChanged"
                      Unchecked="Field_CheckChanged"/>

            <!-- ── Created / Last Login (read-only) ── -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Created At" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="CreatedAtBox" Style="{StaticResource ReadOnlyBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Last Login" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="LastLoginBox" Style="{StaticResource ReadOnlyBox}"/>
                </StackPanel>
            </Grid>

            <!-- ── Save / Discard ── -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="Save Changes"
                        Width="130" Height="32"
                        Margin="0,0,10,0"
                        IsEnabled="{Binding IsDirty, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Click="Save_Click"/>
                <Button Content="Discard"
                        Width="90" Height="32"
                        IsEnabled="{Binding IsDirty, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Click="Discard_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
