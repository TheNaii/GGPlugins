<UserControl x:Class="LoLAM.Module.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Subtle, launcher-like selection instead of Windows bright blue -->
        <Style x:Key="AccountListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <!-- This border is what paints selection. Force it to NOT stretch -->
                        <Border x:Name="Bd"
                        CornerRadius="8"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="Transparent"
                        Padding="8,6"
                        HorizontalAlignment="Left"
                        SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Left"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#141A22"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#171F29"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2E3A4A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Details button: outline style so it stays visible on selection -->
        <Style x:Key="DetailsButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2E3A4A"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#141A22"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#10161E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24"
          TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">

        <!-- Main container anchored to the top and stretching with the host window -->
        <Border CornerRadius="12"
                Padding="18"
                Background="{DynamicResource CardBackgroundBrush}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="LoL Account Manager" FontSize="22" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SignedInText}" Opacity="0.75" Margin="0,4,0,0"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding SaveStatusText}"
                               Opacity="0.75"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <!-- Actions row (wraps on smaller window sizes) -->
                <WrapPanel Grid.Row="1" Margin="0,0,0,12" VerticalAlignment="Top">
                    <Button Content="Add"
                            Width="110"
                            Height="34"
                            Margin="0,0,10,10"
                            Click="Add_Click"/>

                    <Button Content="Remove"
                            Width="110"
                            Height="34"
                            Margin="0,0,10,10"
                            Click="Remove_Click"
                            IsEnabled="{Binding HasSelection}"/>

                    <Button Content="Launch Client"
                            Width="140"
                            Height="34"
                            Margin="0,0,10,10"
                            Click="LaunchClient_Click"
                            IsEnabled="{Binding HasSelection}"/>

                    <ComboBox Height="34"
                              Width="170"
                              Margin="0,0,10,10"
                              SelectedValue="{Binding SelectedSort, Mode=TwoWay}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="Sort Accounts" IsSelected="True" Tag="None"/>
                        <ComboBoxItem Content="Name (A–Z)" Tag="NameAsc"/>
                        <ComboBoxItem Content="Last Login (Newest)" Tag="LastLoginDesc"/>
                        <ComboBoxItem Content="Games Played (Most)" Tag="GamesPlayedDesc"/>
                        <ComboBoxItem Content="Created (Newest)" Tag="CreatedDesc"/>
                    </ComboBox>
                </WrapPanel>

                <!-- Server tabs + accounts list -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Server tabs (single selection using GroupName) -->
                    <ItemsControl Grid.Row="0"
                                  ItemsSource="{Binding Servers}"
                                  Margin="0,0,0,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton GroupName="ServerTabs"
                     Margin="0,0,10,0"
                     Padding="14,8"
                     Click="ServerTab_Click"
                     Content="{Binding}">
                                    <RadioButton.Template>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border x:Name="Bd"
                            CornerRadius="6"
                            Background="{DynamicResource CardBackgroundBrush}"
                            Padding="{TemplateBinding Padding}"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1">
                                                <!-- Transparent hit-test layer so the whole button is clickable -->
                                                <Grid Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#171F29"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#2E3A4A"/>
                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </RadioButton.Template>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- List (fills remaining space, no floating/overlap) -->
                    <Border Grid.Row="1"
                            CornerRadius="12"
                            Padding="10"
                            Background="{DynamicResource CardBackgroundBrush}">
                        <ListBox ItemsSource="{Binding AccountsView}"
                                 SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                                 BorderThickness="0"
                                ItemContainerStyle="{StaticResource AccountListItemStyle}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2" MaxWidth="760" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <!-- Fixed content width so selection highlight doesn't stretch with window -->
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                    CornerRadius="6"
                    Padding="10,6">
                                            <TextBlock Text="{Binding DisplayLabel}"
                           FontWeight="SemiBold"/>
                                        </Border>

                                        <Button Grid.Column="1"
        Content="Details"
        Margin="10,0,0,0"
        Click="OpenDetails_Click"
        VerticalAlignment="Center">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DetailsButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                             Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
