<UserControl x:Class="LoLAM.Module.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      PreviewKeyDown="Page_PreviewKeyDown">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="LinkButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Use launcher foreground by default -->
    <Grid Margin="32"
          TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">

        <Border CornerRadius="12"
        Padding="24"
        MaxWidth="560"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="{DynamicResource CardBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="LoL Account Manager" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock Text="Sign in or register to load accounts from the cloud."
                       Opacity="0.75" Margin="0,6,0,18"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Email" Opacity="0.8"/>
                    <TextBox x:Name="EmailBox" Height="36" Margin="0,6,0,14"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Password" Opacity="0.8"/>
                    <PasswordBox x:Name="PasswordBox" Height="36" Margin="0,6,0,6"/>
                </StackPanel>

                <!-- Remember Me -->
                <CheckBox x:Name="RememberMeBox"
                          Grid.Row="3"
                          Content="Remember Me"
                          IsChecked="True"
                          Margin="0,4,0,8"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          Opacity="0.85"/>

                <Border Grid.Row="4" Margin="0,0,0,12"
                Padding="10"
                CornerRadius="8"
                Background="{DynamicResource CardBackgroundBrush}"
                Visibility="Collapsed"
                x:Name="StatusContainer">
                    <TextBlock x:Name="StatusText" TextWrapping="Wrap" Opacity="0.9"/>
                </Border>

                <!-- Buttons + Forgot password centered below -->
                <StackPanel Grid.Row="5" Margin="0,15,0,0" HorizontalAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="LoginButton"
                Grid.Column="0"
                IsDefault="True"
                Content="Login"
                Width="120"
                Height="36"
                Click="Login_Click"/>

                        <Button x:Name="RegisterButton"
                Grid.Column="2"
                Content="Register"
                Width="120"
                Height="36"
                Click="Register_Click"/>
                    </Grid>

                    <Button x:Name="ForgotPasswordButton"
            Style="{StaticResource LinkButtonStyle}"
            Click="ForgotPassword_Click"
            HorizontalAlignment="Center"
            Margin="0,16,0,0"
            Padding="0"
            BorderThickness="0"
            Background="Transparent"
            Cursor="Hand"
            Opacity="0.75">
                        <TextBlock Text="Forgot password?"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextDecorations" Value="{x:Null}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=ForgotPasswordButton}" Value="True">
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
