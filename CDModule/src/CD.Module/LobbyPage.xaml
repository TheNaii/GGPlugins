<UserControl x:Class="CD.Module.LobbyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="RoleFilterBtn" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="4"
                                Background="Transparent"
                                Padding="6,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem style for dark theme -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Padding" Value="8,5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Top bar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="Auto"/>  <!-- Bottom: notes + bans -->
        </Grid.RowDefinitions>

        <!-- ══ Top bar ══ -->
        <Border Grid.Row="0" Background="#0F172A" Padding="14,8">
            <DockPanel>
                <TextBlock x:Name="LobbyTitle"
                           Text="Lobby"
                           FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <!-- Right side controls -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">

                    <TextBlock Text="Bans:" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="BansCombo" Width="50" Height="26"
                              VerticalContentAlignment="Center" Padding="6,0"
                              SelectionChanged="Bans_Changed">
                        <ComboBoxItem Content="1" Tag="1"/>
                        <ComboBoxItem Content="2" Tag="2"/>
                        <ComboBoxItem Content="3" Tag="3"/>
                        <ComboBoxItem Content="4" Tag="4"/>
                        <ComboBoxItem Content="5" Tag="5"/>
                    </ComboBox>

                    <Button Style="{StaticResource SmallButton}"
                            Content="Leave" Margin="14,0,0,0"
                            Foreground="#FF6B6B"
                            Click="Leave_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ Main content ══ -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>  <!-- Team panel -->
                <ColumnDefinition Width="*"/>    <!-- Champion grid -->
            </Grid.ColumnDefinitions>

            <!-- ── Team Panel (left) ── -->
            <Border Grid.Column="0" Background="#0F172A" Padding="10,10">
                <StackPanel x:Name="TeamPanel"/>
            </Border>

            <!-- ── Champion Grid (center) ── -->
            <Grid Grid.Column="1" Margin="10,10,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Mode hint -->
                    <RowDefinition Height="Auto"/>  <!-- Search + filters -->
                    <RowDefinition Height="*"/>     <!-- Grid -->
                </Grid.RowDefinitions>

                <!-- Mode hint -->
                <TextBlock Grid.Row="0" x:Name="ModeHint"
                           FontSize="10" Opacity="0.4"
                           Margin="0,0,0,4"
                           Text="Left-click a champion to assign to selected role. Right-click to ban."/>

                <!-- Search + role filters -->
                <DockPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBox x:Name="SearchBox"
                             Width="200" Height="28"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             TextChanged="Search_Changed"/>

                    <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <ToggleButton x:Name="FilterAll"     Style="{StaticResource RoleFilterBtn}" Content="All"  Click="Filter_Click" IsChecked="True"/>
                        <ToggleButton x:Name="FilterTop"     Style="{StaticResource RoleFilterBtn}" Content="⚔"   Click="Filter_Click" ToolTip="Top / Fighter"/>
                        <ToggleButton x:Name="FilterJungle"  Style="{StaticResource RoleFilterBtn}" Content="🌲"  Click="Filter_Click" ToolTip="Jungle / Tank"/>
                        <ToggleButton x:Name="FilterMid"     Style="{StaticResource RoleFilterBtn}" Content="🔮"  Click="Filter_Click" ToolTip="Mid / Mage"/>
                        <ToggleButton x:Name="FilterAdc"     Style="{StaticResource RoleFilterBtn}" Content="🏹"  Click="Filter_Click" ToolTip="ADC / Marksman"/>
                        <ToggleButton x:Name="FilterSupport" Style="{StaticResource RoleFilterBtn}" Content="🛡"  Click="Filter_Click" ToolTip="Support"/>
                    </WrapPanel>
                </DockPanel>

                <!-- Champion icons grid -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="ChampionGrid"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ══ Bottom bar: Notes + Bans ══ -->
        <Border Grid.Row="2" Background="#0F172A" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Shared notes -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Shared Notes" FontSize="11" Opacity="0.55" Margin="0,0,0,4"/>
                    <TextBox x:Name="NotesBox"
                             Height="60" FontSize="12"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="6,4"
                             TextChanged="Notes_Changed"/>
                </StackPanel>

                <!-- Bans display -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Bans" FontSize="11" Opacity="0.55" Margin="0,0,0,4"/>
                    <WrapPanel x:Name="BansPanel"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
